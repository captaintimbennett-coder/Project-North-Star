# PostgreSQL connection supplied by the database provider.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=verify-full

# Generate a long, private value. Never expose this in browser code.
PAYLOAD_SECRET=replace-with-a-long-random-secret

# Local development URL. Change this for preview and production deployments.
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Public canonical site URL used in secure account links.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Production transactional email. Required before real invitations/password recovery.
SENDGRID_API_KEY=replace-with-sendgrid-api-key
SENDGRID_FROM_EMAIL=no-reply@example.com
SENDGRID_FROM_NAME=Tim Bennett · Project North Star
SENDGRID_REPLY_TO=hello@example.com
SENDGRID_SANDBOX_MODE=true

# Internal design-review route only. Keep disabled in production.
ENABLE_CALENDAR_PROTOTYPE=false
